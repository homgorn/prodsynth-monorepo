{
  "$schema": "https://turbo.build/schema.json",
  "globalDependencies": ["**/.env.*local"],
  "pipeline": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [
        "dist/**",
        ".next/**",
        "build/**"
      ]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["build"],
      "outputs": ["coverage/**"]
    },
    "lint": {
      "outputs": []
    },
    "clean": {
      "cache": false
    },
    "apps/backend#build": {
      "dependsOn": ["packages/core#build", "packages/agents#build", "packages/graph#build"],
      "outputs": ["dist/**"]
    },
    "apps/frontend#build": {
      "dependsOn": ["packages/ui#build"],
      "outputs": [".next/**"]
    },
    "apps/cli#build": {
      "outputs": ["dist/**"]
    }
  }
}
